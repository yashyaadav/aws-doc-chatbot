# Copy to .env and fill in. Loaded for local dev via `set -a; source .env`.
# NOTE: contains no secrets — AWS creds come from the named profile below.

# --- AWS / Bedrock ---
AWS_PROFILE=assignment
AWS_REGION=us-east-1
# Claude Opus 4.8 via the global cross-region inference profile.
BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-8

# --- Agent behaviour ---
AGENT_MAX_TOKENS=8000
AGENT_MAX_TOOL_ITERATIONS=8

# --- Conversation store ---
# Leave blank for local dev (in-memory). Set to the DynamoDB table name once deployed.
CONVERSATIONS_TABLE=

# --- Auth (Cognito) ---
# false for local dev; true in deployed environments.
AUTH_ENABLED=false
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# --- Local server ---
PORT=8080
